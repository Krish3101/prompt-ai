# ===== PromptSmith Environment Configuration =====
# Copy this file to .env and fill in your values

# ===== API CONFIGURATION =====
# API Backend Selection
# If OPENROUTER_API_KEY is not set, the app will run in "Offline Mode" 
# and use a hardcoded fallback template to assist you locally.

# Get your FREE API key from: https://openrouter.ai/keys
# OpenRouter offers a free tier with models like Mistral 7B
OPENROUTER_API_KEY=

# ===== APPLICATION SETTINGS =====
# Flask environment (development, production)
FLASK_ENV=development
DEBUG=True
PORT=5001
HOST=localhost

# ===== INSTRUCTIONS =====
# 1. Copy this file: cp .env.example .env
# 2. Add your OPENROUTER_API_KEY if you want LLM features
# 3. Never commit .env to version control!
