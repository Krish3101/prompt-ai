# ===== PromptSmith Environment Configuration =====
# Copy this file to .env and fill in your values

# ===== API CONFIGURATION =====
# API Backend: Choose "openrouter", "lmstudio", "ollama", or "custom"
API_BACKEND=openrouter

# OpenRouter Configuration (when API_BACKEND=openrouter)
# Get your FREE API key from: https://openrouter.ai/keys
# OpenRouter offers free tier with models like Mistral 7B
OPENROUTER_API_KEY=your_api_key_here

# LM Studio Configuration (when API_BACKEND=lmstudio)
# Default LM Studio endpoint
LMSTUDIO_API_URL=http://localhost:1234/v1/chat/completions

# Ollama Configuration (when API_BACKEND=ollama)
# Default Ollama endpoint
OLLAMA_API_URL=http://localhost:11434/api/generate

# Custom API Configuration (when API_BACKEND=custom)
# Set your custom API endpoint and optional API key
CUSTOM_API_URL=http://localhost:8000/v1/chat/completions
CUSTOM_API_KEY=

# ===== APPLICATION SETTINGS =====
# Flask environment (development, production)
FLASK_ENV=development

# Enable debug mode (True/False)
DEBUG=True

# Server port
PORT=5001

# Server host
HOST=localhost

# ===== API SETTINGS =====
# API timeout in seconds
API_TIMEOUT_SECONDS=30

# Default model for each backend
# For OpenRouter, use format: provider/model-name
# For LM Studio/Ollama, use the model name loaded in the server
DEFAULT_MODEL=mistralai/mistral-7b-instruct:free

# ===== CACHE SETTINGS =====
# How long to cache data (in days)
CACHE_DURATION_DAYS=7

# Maximum number of history entries to keep
MAX_HISTORY_ENTRIES=100

# ===== FEATURE FLAGS =====
# Enable/disable specific features (True/False)
ENABLE_WEB_SEARCH=True
ENABLE_AB_TESTING=True
ENABLE_QUALITY_SCORER=True
ENABLE_HISTORY=True

# ===== WEB SEARCH SETTINGS =====
# Maximum search results to fetch
SEARCH_MAX_RESULTS=3

# Search timeout in seconds
SEARCH_TIMEOUT=10

# ===== LOGGING =====
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===== INSTRUCTIONS =====
# 1. Copy this file: cp .env.example .env
# 2. Add your OPENROUTER_API_KEY
# 3. Adjust other settings as needed
# 4. Never commit .env to version control!
